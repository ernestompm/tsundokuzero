# Copiar a .env.local y rellenar con los valores del proyecto Supabase
# (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Código que se pide al crear cuenta (grupo cerrado de amigos)
VITE_INVITE_CODE=elige-un-codigo

# Botón «Continuar con Google» (activar también el proveedor en Supabase)
VITE_AUTH_GOOGLE_ENABLED=false
